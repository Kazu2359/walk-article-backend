# 本番(Neon/Upstash)に対してローカルからスクリプト(cost-summary.ts, smoke-test.ts等)を
# 実行するための.env雛形。このファイルを .env という名前でコピーし、
# 下記の空欄を埋めれば使える。
#
#   cp env.production.sample .env
#   （その後、下記を実際の値に書き換えて保存）

# ↓ Neonのダッシュボードから接続文字列をコピーして貼り付け
DATABASE_URL=""

# ↓ Upstashのダッシュボードの「TCP」タブから接続文字列をコピーして貼り付け（rediss://で始まるもの）
REDIS_URL=""

# ↓ fly secrets set時に控えた値を貼り付け（Fly側の値と一致させる必要がある）
JWT_SECRET=""

APPLE_BUNDLE_ID="com.kazu2359.walkarticleapp"
