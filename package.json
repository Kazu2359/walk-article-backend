{
  "name": "walk-article-backend",
  "version": "0.1.0",
  "description": "散歩記事化アプリ バックエンドAPI（アップロード→文字起こし→記事生成）",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/workers/transcribeAndGenerate.worker.ts",
    "retention:dev": "tsx watch src/workers/audioRetention.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker:start": "node dist/workers/transcribeAndGenerate.worker.js",
    "retention:start": "node dist/workers/audioRetention.worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.80.8",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
